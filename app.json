{
  "expo": {
    "name": "North Star Appraiser",
    "slug": "northstar-appraiser",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "northstarappraiser",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.athenadecisionsystems.northstar.appraiser",
      "infoPlist": {
        "NSCameraUsageDescription": "North Star uses the camera to capture property photos during on-site inspections. Photos stay on your device until you upload them to a workfile.",
        "NSMicrophoneUsageDescription": "North Star uses the microphone to record voice notes during on-site inspections.",
        "NSLocationWhenInUseUsageDescription": "North Star uses your location to geotag inspection photos so the audit chain can witness where each photo was taken.",
        "NSPhotoLibraryUsageDescription": "North Star imports photos from your library for inclusion in a workfile.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.athenadecisionsystems.northstar.appraiser",
      "adaptiveIcon": {
        "backgroundColor": "#0f1d3a",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f3ecdb",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 180,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 180,
            "backgroundColor": "#0f1d3a"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "apiBase": "https://appraisal.athenanorthstar.com"
    }
  }
}
